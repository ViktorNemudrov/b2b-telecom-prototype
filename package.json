{
  "name": "b2b-telecom-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:ai": "npm run dev -w @b2b/ai-first",
    "dev:classic": "npm run dev -w @b2b/classic",
    "build:ai": "npm run build -w @b2b/ai-first",
    "build:classic": "npm run build -w @b2b/classic",
    "build": "npm run build:ai && npm run build:classic",
    "lint:ai": "npm run lint -w @b2b/ai-first",
    "lint:classic": "npm run lint -w @b2b/classic",
    "lint": "npm run lint:ai && npm run lint:classic",
    "mobile:sync": "npm run mobile:sync -w @b2b/ai-first",
    "mobile:android": "npm run mobile:android -w @b2b/ai-first"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
