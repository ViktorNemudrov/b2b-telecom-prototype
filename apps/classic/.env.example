# Скопируйте в `.env.local` и заполните значения. Файл `.env.local` не коммитится.
# Дополнительно: можно положить те же `NEXT_PUBLIC_*` в `.env.local` в корне монорепозитория —
# при сборке/запуске Classic они подхватятся, если в `apps/classic/.env.local` ключ ещё не задан.
# Live AI: порядок перебора — Gemini → Together → OpenRouter → Grok → Groq (есть ключ — провайдер участвует).

NEXT_PUBLIC_OPENROUTER_API_KEY=
NEXT_PUBLIC_OPENROUTER_MODEL=

NEXT_PUBLIC_GROK_API_KEY=
NEXT_PUBLIC_GROK_MODEL=

NEXT_PUBLIC_GROQ_API_KEY=
NEXT_PUBLIC_GROQ_MODEL=

NEXT_PUBLIC_GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_MODEL=

NEXT_PUBLIC_TOGETHER_API_KEY=
NEXT_PUBLIC_TOGETHER_MODEL=

# Опционально: свой прокси (полный URL). Если не задано, используется встроенный same-origin `/api/llm` (Next Route Handlers).
# NEXT_PUBLIC_LLM_PROXY_URL=
