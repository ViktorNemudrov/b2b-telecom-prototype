{
  "installCommand": "npm install",
  "buildCommand": "npm run build && npx --yes next export --outdir out",
  "outputDirectory": "out",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "out"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ]
}

